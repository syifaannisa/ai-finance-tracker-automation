    {
      "parameters": {
        "jsCode": "const filePath = $input.first().json.result.file_path;\nconst token = $env.TELEGRAM_BOT_TOKEN;\n\n// Download PDF dan convert ke base64\nconst imageUrl = `https://api.telegram.org/file/bot${token}/${filePath}`;\n\nconst response = await this.helpers.httpRequest({\n  method: 'GET',\n  url: imageUrl,\n  encoding: 'arraybuffer',  // Penting! Sama seperti yang kita pakai di receipt image\n  returnFullResponse: false,\n});\n\nconst base64 = Buffer.from(response).toString('base64');\n\nreturn [{\n  json: {\n    base64Data: base64,\n    mimeType: 'application/pdf',\n    filePath: filePath\n  }\n}];"
      },
      "id": "5ea58c8d-c5f0-4611-95b2-d354bab75fd9",
