    {
      "parameters": {
        "jsCode": "const filePath = $input.first().json.result.file_path;\nconst token = $env.TELEGRAM_BOT_TOKEN;\nconst trigger = $('Telegram Trigger').first().json;\n\nconst imageUrl = `https://api.telegram.org/file/bot${token}/${filePath}`;\n\n// Download pakai helper n8n (bukan fetch)\nconst response = await this.helpers.httpRequest({\n  method: 'GET',\n  url: imageUrl,\n  encoding: 'arraybuffer',\n  returnFullResponse: false\n});\n\nconst base64 = Buffer.from(response).toString('base64');\n\nconst ext = filePath.split('.').pop().toLowerCase();\nconst mimeMap = { jpg: 'image/jpeg', jpeg: 'image/jpeg', png: 'image/png', webp: 'image/webp' };\nconst mimeType = mimeMap[ext] || 'image/jpeg';\n\nreturn [{\n  json: {\n    chat_id: trigger.message.chat.id,\n    input_date: new Date(trigger.message.date * 1000).toISOString().split('T')[0],\n    input_type: 'photo',\n    text_content: '',\n    image_base64: base64,\n    image_mime: mimeType,\n    has_image: true\n  }\n}];"
      },
