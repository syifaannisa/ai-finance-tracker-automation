      "id": "9ecda01e-4e1d-4feb-9cb7-d170f4a22d99",
      "name": "Read Sheets Data",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        -496,
        736
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "XHVoEvkw16nN8yjL",
          "name": "Google Sheets account 479"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const allRows = $input.all().map(i => i.json);\n\nconst now = new Date();\nconst lastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);\nconst lastMonthStr = lastMonth.toISOString().slice(0,7);\n\nconst filtered = allRows.filter(r => r['Date'] && r['Date'].startsWith(lastMonthStr));\n\nconst monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];\nconst monthName = monthNames[lastMonth.getMonth()];\n\nif (filtered.length === 0) {\n  return [{ json: {\n    report: `📊 *${monthName} ${lastMonth.getFullYear()} Report*\\n\\n_No transactions recorded this month._`,\n    chat_id: 'YOUR_CHAT_ID'\n  }}];\n}\n\nconst perCategory = {};\nlet totalAll = 0;\nfiltered.forEach(r => {\n  const cat = r['Category'] || 'Others';\n  const amt = parseFloat(r['Amount (USD)']) || 0;\n  perCategory[cat] = (perCategory[cat] || 0) + amt;\n  totalAll += amt;\n});\n\nconst sorted = Object.entries(perCategory).sort((a,b) => b[1]-a[1]);\n\nconst emoji = {\n  'Food & Beverage':'🍜','Transportation':'🚗','Investment':'📈',\n  'Charity & Donation':'🤲','Bills':'💡','Shopping':'🛍️',\n  'Health':'💊','Entertainment':'🎬','Education':'📚','Others':'📌'\n};\n\nlet text = `📊 *Financial Report — ${monthName} ${lastMonth.getFullYear()}*\\n`;\ntext += `━━━━━━━━━━━━━━━━━━\\n`;\nsorted.forEach(([cat, amt]) => {\n  const pct = Math.round(amt/totalAll*100);\n  text += `\\n${emoji[cat]||'📌'} *${cat}*\\n$${amt.toFixed(2)} (${pct}%)\\n`;\n});\ntext += `\\n━━━━━━━━━━━━━━━━━━`;\ntext += `\\n💰 *Total: $${totalAll.toFixed(2)}*`;\ntext += `\\n📝 ${filtered.length} transactions`;\n\nreturn [{ json: { report: text, chat_id: 'YOUR_CHAT_ID' } }];"
      },
