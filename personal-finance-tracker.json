    {
      "parameters": {
        "jsCode": "const trigger = $('Telegram Trigger').first().json;\nconst chatId  = trigger.message.chat.id;\nconst msgDate = new Date(trigger.message.date * 1000).toISOString().split('T')[0];\n\n// Input from Whisper (voice)\nconst textFromWhisper = $input.first().json.text || '';\n\nreturn [{\n  json: {\n    chat_id:       chatId,\n    input_date: msgDate,\n    input_type:    'voice_to_text',\n    text_content:  textFromWhisper,\n    image_url:     null,\n    has_image:     false\n  }\n}];"
      },
      "id": "cc3d90bd-8749-49f9-a1e1-06cf716749a0",
      "name": "Prepare Transcribed Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        528
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Check if there is PDF data from Build Document URL\nlet pdfBase64 = null;\nlet pdfMime = null;\n\ntry {\n  const docData = $('Build Document URL').first().json;\n  if (docData && docData.base64Data) {\n    pdfBase64 = docData.base64Data;\n    pdfMime = docData.mimeType || 'application/pdf';\n  }\n} catch(e) {\n  // No document found, that's fine\n}\n\nreturn [{\n  json: {\n    chat_id:      item.chat_id,\n    input_date:   item.input_date,\n    input_type:   item.input_type,\n    text_content: item.text_content || '',\n    image_url:    item.image_url || null,\n    // If a PDF exists, use it. Otherwise use the photo\n    image_base64: pdfBase64 || item.image_base64 || null,\n    image_mime:   pdfMime || item.image_mime || 'image/jpeg',\n    has_image:    !!(pdfBase64 || item.image_base64),\n  }\n}];"
      },
      "id": "f09ffe8f-7bbc-4432-aad2-1ebccdaee74f",
      "name": "Merge All Inputs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Concise prompt so the output isn't truncated\nconst instruksi = \"You are a financial assistant. Extract the data from the receipt/invoice/text.\\n\" +\n\"Detect the original currency of the transaction (IDR, USD, SGD, MYR, EUR, JPY, GBP, AUD, or any other currency) and convert the total to US Dollars (USD) using standard current exchange rates. If the original currency is already USD, keep the amount as is.\\n\" +\n\"Default date if none is found: \" + item.input_date + \"\\n\" +\n\"Category: Food & Beverage / Transportation / Investment / Charity & Donation / Bills / Shopping / Health / Entertainment / Education / Others\\n\" +\n\"If there are multiple items, MERGE them into 1 entry per category (do not split per item).\\n\" +\n\"Write the merchant name, item summary, and confirmation message in professional English.\\n\\n\" +\n\"INPUT: \" + (item.text_content || \"see image\") + \"\\n\\n\" +\n\"REPLY WITH JSON ONLY:\\n\" +\n\"{\\\"success\\\":true,\\\"entries\\\":[{\\\"date\\\":\\\"YYYY-MM-DD\\\",\\\"merchant\\\":\\\"name\\\",\\\"category\\\":\\\"category\\\",\\\"item\\\":\\\"item summary\\\",\\\"original_amount\\\":0,\\\"original_currency\\\":\\\"USD\\\",\\\"amount_usd\\\":0,\\\"notes\\\":\\\"\\\"}],\\\"total_usd\\\":0,\\\"confirmation_message\\\":\\\"✅ $X for Category at Merchant on Y\\\"}\\n\" +\n\"If this is not financial information: {\\\"success\\\":false,\\\"confirmation_message\\\":\\\"❌ No financial information found.\\\"}\";\n\nconst parts = [{ text: instruksi }];\n\nif (item.has_image && item.image_base64) {\n  parts.push({\n    inline_data: {\n      mime_type: item.image_mime || \"image/jpeg\",\n      data: item.image_base64\n    }\n  });\n}\n\nconst requestBody = {\n  contents: [{ parts: parts }],\n  generationConfig: {\n    temperature: 0.1,\n    maxOutputTokens: 8192\n  }\n};\n\nreturn [{\n  json: {\n    chat_id: item.chat_id,\n    input_date: item.input_date,\n    input_type: item.input_type,\n    gemini_body: JSON.stringify(requestBody)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        208
      ],
      "id": "5381915a-e1a1-4a7c-a2b7-bd2980fc770b",
      "name": "Build Gemini Prompt"
    },
    {
      "parameters": {
        "jsCode": "const trigger  = $('Telegram Trigger').first().json;\nconst chatId   = trigger.message.chat.id;\nconst prepared = $('Build Gemini Prompt').first().json;\n\nlet rawText = '';\ntry {\n  rawText = $input.first().json.candidates[0].content.parts[0].text || '';\n} catch(e) {\n  return [{ json: {\n    success: false,\n    message: '❌ Gemini did not respond. Please try sending it again.',\n    chat_id: chatId\n  }}];\n}\n\n// Remove markdown code fences\nconst cleaned = rawText\n  .replace(/```json\\n?/g, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\ntry {\n  const parsed = JSON.parse(cleaned);\n\n  if (!parsed.success) {\n    return [{ json: {\n      success: false,\n      message: parsed.confirmation_message || '❌ Unable to process this input.',\n      chat_id: chatId\n    }}];\n  }\n\n  return parsed.entries.map(entry => ({\n    json: {\n      success:            true,\n      date:               entry.date               || prepared.input_date,\n      merchant:           entry.merchant            || 'Unknown merchant',\n      category:           entry.category            || 'Others',\n      item:               entry.item                || '-',\n      original_amount:    entry.original_amount      || 0,\n      original_currency:  entry.original_currency    || 'USD',\n      amount_usd:         entry.amount_usd           || 0,\n      notes:              entry.notes               || '',\n      total_usd:          parsed.total_usd           || 0,\n      confirmation_message: parsed.confirmation_message || '✅ Data recorded successfully.',\n      chat_id:            chatId\n    }\n  }));\n\n} catch(e) {\n  return [{ json: {\n    success: false,\n    message: '❌ Failed to read the AI response. Please try again.',\n    chat_id: chatId\n  }}];\n}"
      },
